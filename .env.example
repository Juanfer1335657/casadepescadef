# =============================================
# Variables de Entorno - La Casa De La Pesca Villavicencio
# =============================================

# Base de datos (Neon PostgreSQL)
# Obtén tu URL en https://neon.tech
DATABASE_URL=postgresql://username:password@host/neondb?sslmode=require

# JWT para sesiones de admin
JWT_SECRET=la-casa-de-pesca-secret-key-2024-secure

# Vercel Blob (token de lectura/escritura)
# Obtén tu token en https://vercel.com/dashboard/blob
BLOB_READ_WRITE_TOKEN=tu_token_aqui

# Número de WhatsApp (formato internacional sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=573225908400

# Credenciales de Administrador
ADMIN_EMAIL=admin@lacasadelapesca.com
ADMIN_PASSWORD=admin123